// Secrets.xcconfig
//
// Copy this file to Secrets.xcconfig and fill in your values.
// Secrets.xcconfig is gitignored and will not be committed.
//
// DEVELOPMENT_TEAM: Your Apple Developer Team ID for code signing.
// Find it at https://developer.apple.com/account → Membership details.

DEVELOPMENT_TEAM = your_team_id_here

// TAVILY_API_KEY: Enables the Web Search built-in tool. Obtain one at:
// https://app.tavily.com/home
// If left empty or omitted, the Web Search tool will not be available.

TAVILY_API_KEY = your_tavily_api_key_here
